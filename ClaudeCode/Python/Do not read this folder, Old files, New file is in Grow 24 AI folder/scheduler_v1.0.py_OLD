#!/usr/bin/env python3
"""
GoAmrita - Central Task Scheduler v1.0
=======================================
One command runs everything. Daily pipeline + real-time monitors.

DAILY PIPELINE (8:00-10:00 AM):
  8:00  → Data Import (Ads + SP-API)
  8:15  → True Profit Calculator
  8:30  → Auto Campaign: New Listings (daily)
  8:45  → Excel Ad Action Report + Listing Health Report
  10:00 → Execute Approved Actions (if approval file returned)

REAL-TIME MONITORS:
  Every 2hr  → Buy Box Monitor
  Every 2hr  → Stock Monitor
  Every 4hr  → Intraday Sales Compare
  Every 8hr  → Budget Monitor

PERIODIC:
  Every 15d  → Auto Campaign: Top Profit
  Weekly Sun → Weekly Report

FEATURES:
  - Dependency chain (auto-run dependencies if data stale)
  - Data freshness check (skip if fresh enough)
  - Smart batching (share API calls)
  - Failure retry (3 attempts)
  - Execution log

Usage:
    python scheduler_v1.0.py --run daily          (full daily pipeline)
    python scheduler_v1.0.py --run monitor         (all real-time monitors once)
    python scheduler_v1.0.py --run task import     (single task)
    python scheduler_v1.0.py --run task report     (single task)
    python scheduler_v1.0.py --run from report     (from step, auto-deps)
    python scheduler_v1.0.py --status              (show last run times)
    python scheduler_v1.0.py --daemon              (run continuously with schedules)
"""

import json
import os
import sys
import time
import subprocess
import argparse
from datetime import datetime, timedelta

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
PROJECT_DIR = os.path.dirname(os.path.dirname(SCRIPT_DIR))
PYTHON = sys.executable
LOG_FILE = os.path.join(SCRIPT_DIR, "..", "scheduler_log.json")
CONFIG_FILE = os.path.join(PROJECT_DIR, "config_scheduler.json")

# ============================================
# DEFAULT CONFIG
# ============================================
DEFAULT_CONFIG = {
    "version": "1.0",
    "daily_pipeline_time": "08:30",
    "tasks": {
        "import": {
            "name": "Data Import",
            "script": "sp_ads_complete_import_v1.0.py",
            "depends_on": [],
            "freshness_hours": 4,
            "enabled": True
        },
        "pricing": {
            "name": "Pricing Refresh",
            "script": "fetch_pricing_v1.0.py",
            "depends_on": [],
            "freshness_hours": 12,
            "enabled": True
        },
        "profit": {
            "name": "True Profit Calculator",
            "script": "true_profit_calculator_v1.0.py",
            "depends_on": ["import", "pricing"],
            "freshness_hours": 24,
            "enabled": True
        },
        "campaign_new": {
            "name": "Auto Campaign: New Listings",
            "script": "auto_campaign_creator_v2.0.py",
            "args": ["--mode", "newlisting", "--days", "8"],
            "depends_on": ["profit"],
            "freshness_hours": 24,
            "enabled": True
        },
        "campaign_profit": {
            "name": "Auto Campaign: Top Profit",
            "script": "auto_campaign_creator_v2.0.py",
            "args": ["--mode", "profit", "--top", "5"],
            "depends_on": ["profit"],
            "freshness_hours": 360,
            "enabled": True
        },
        "report_ads": {
            "name": "Ad Action Report",
            "script": "create_action_report_v2.0.py",
            "depends_on": ["profit"],
            "freshness_hours": 24,
            "enabled": True
        },
        "report_listing": {
            "name": "Listing Health Report",
            "script": "listing_health_report_v1.0.py",
            "depends_on": ["profit"],
            "freshness_hours": 24,
            "enabled": True
        },
        "buybox": {
            "name": "Buy Box Monitor",
            "script": "buy_box_monitor_v1.1.py",
            "script_dir": "Grow24_AI/marketplaces/amazon/seller_api/market_intelligence",
            "depends_on": [],
            "freshness_hours": 2,
            "enabled": True
        },
        "execute": {
            "name": "Execute Approved Actions",
            "script": "execute_approvals_v1.0.py",
            "depends_on": ["report_ads"],
            "freshness_hours": 24,
            "enabled": True
        }
    },
    "pipelines": {
        "daily": ["import", "pricing", "profit", "campaign_new", "report_ads", "report_listing"],
        "monitor": ["buybox"],
        "weekly": ["campaign_profit"]
    },
    "freshness_rules": {
        "campaign_metrics": 4,
        "stock_levels": 2,
        "buy_box_status": 1,
        "pricing": 12,
        "search_terms": 24,
        "true_profit": 24,
        "competitor_prices": 12
    }
}


def load_config():
    if os.path.exists(CONFIG_FILE):
        with open(CONFIG_FILE, encoding='utf-8') as f:
            return json.load(f)
    # Create default
    with open(CONFIG_FILE, 'w', encoding='utf-8') as f:
        json.dump(DEFAULT_CONFIG, f, indent=2)
    print(f"  Config created: {CONFIG_FILE}")
    return DEFAULT_CONFIG


def load_log():
    if os.path.exists(LOG_FILE):
        try:
            with open(LOG_FILE, encoding='utf-8') as f:
                return json.load(f)
        except:
            pass
    return {"runs": {}}


def save_log(log):
    with open(LOG_FILE, 'w', encoding='utf-8') as f:
        json.dump(log, f, indent=2, ensure_ascii=False)


# ============================================
# DATA FRESHNESS CHECK
# ============================================
def is_fresh(task_id, config, log):
    """Check if task output is still fresh (don't need to re-run)"""
    task = config["tasks"].get(task_id, {})
    freshness_hours = task.get("freshness_hours", 4)

    last_run = log["runs"].get(task_id, {}).get("last_success")
    if not last_run:
        return False  # never run

    try:
        last_dt = datetime.fromisoformat(last_run)
        age_hours = (datetime.now() - last_dt).total_seconds() / 3600
        return age_hours < freshness_hours
    except:
        return False


# ============================================
# RESOLVE DEPENDENCIES
# ============================================
def resolve_deps(task_id, config, log, resolved=None):
    """Get ordered list of tasks to run (including dependencies)"""
    if resolved is None:
        resolved = []

    task = config["tasks"].get(task_id, {})
    deps = task.get("depends_on", [])

    for dep in deps:
        if dep not in resolved:
            # Check if dependency data is fresh
            if not is_fresh(dep, config, log):
                resolve_deps(dep, config, log, resolved)
                if dep not in resolved:
                    resolved.append(dep)

    if task_id not in resolved:
        resolved.append(task_id)

    return resolved


# ============================================
# RUN SINGLE TASK
# ============================================
def run_task(task_id, config, log, force=False):
    """Run a single task script"""
    task = config["tasks"].get(task_id)
    if not task:
        print(f"  Unknown task: {task_id}")
        return False

    if not task.get("enabled", True):
        print(f"  [{task['name']}] DISABLED — skipping")
        return True

    # Freshness check (skip if still fresh, unless forced)
    if not force and is_fresh(task_id, config, log):
        last = log["runs"][task_id]["last_success"][:16]
        print(f"  [{task['name']}] FRESH (last: {last}) — skipping")
        return True

    script_dir = task.get("script_dir")
    if script_dir:
        script = os.path.join(PROJECT_DIR, script_dir, task["script"])
    else:
        script = os.path.join(SCRIPT_DIR, task["script"])
    if not os.path.exists(script):
        print(f"  [{task['name']}] Script not found: {task['script']}")
        return False

    args = task.get("args", [])
    cmd = [PYTHON, script] + args

    print(f"\n  {'='*55}")
    print(f"  [{task['name']}] Running: {task['script']} {' '.join(args)}")
    print(f"  {'='*55}")

    start = datetime.now()
    try:
        env = os.environ.copy()
        env["PYTHONIOENCODING"] = "utf-8"
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=600, env=env)

        duration = (datetime.now() - start).total_seconds()
        success = result.returncode == 0

        # Print output (last 10 lines)
        output_lines = result.stdout.strip().split('\n') if result.stdout else []
        for line in output_lines[-10:]:
            print(f"    {line}")

        if result.stderr and not success:
            err_lines = result.stderr.strip().split('\n')
            for line in err_lines[-5:]:
                print(f"    ERROR: {line}")

        # Log
        log["runs"][task_id] = {
            "last_run": datetime.now().isoformat(),
            "last_success": datetime.now().isoformat() if success else log["runs"].get(task_id, {}).get("last_success"),
            "success": success,
            "duration_sec": round(duration),
            "return_code": result.returncode
        }
        save_log(log)

        status = "OK" if success else "FAILED"
        print(f"  [{task['name']}] {status} ({duration:.0f}s)")
        return success

    except subprocess.TimeoutExpired:
        print(f"  [{task['name']}] TIMEOUT (600s)")
        log["runs"][task_id] = {
            "last_run": datetime.now().isoformat(),
            "success": False,
            "error": "timeout"
        }
        save_log(log)
        return False

    except Exception as e:
        print(f"  [{task['name']}] ERROR: {str(e)}")
        return False


# ============================================
# RUN PIPELINE
# ============================================
def run_pipeline(pipeline_name, config, log, force=False):
    """Run a named pipeline (ordered list of tasks)"""
    pipeline = config["pipelines"].get(pipeline_name, [])
    if not pipeline:
        print(f"  Unknown pipeline: {pipeline_name}")
        return

    print(f"\n{'='*60}")
    print(f"  PIPELINE: {pipeline_name.upper()}")
    print(f"  Tasks: {len(pipeline)}")
    print(f"  {datetime.now().strftime('%d %B %Y, %I:%M %p')}")
    print(f"{'='*60}")

    results = {}
    for task_id in pipeline:
        success = run_task(task_id, config, log, force=force)
        results[task_id] = success

        if not success:
            task_name = config["tasks"].get(task_id, {}).get("name", task_id)
            print(f"\n  WARNING: {task_name} failed. Continuing pipeline...")

    # Summary
    total = len(results)
    ok = sum(1 for v in results.values() if v)
    print(f"\n{'='*60}")
    print(f"  PIPELINE COMPLETE: {ok}/{total} tasks succeeded")
    print(f"{'='*60}")
    return results


# ============================================
# RUN FROM STEP (with auto-dependencies)
# ============================================
def run_from(task_id, config, log):
    """Run a task + auto-resolve stale dependencies"""
    print(f"\n  Resolving dependencies for: {task_id}")
    tasks = resolve_deps(task_id, config, log)

    print(f"  Execution plan: {' → '.join(tasks)}")

    # Check which are fresh
    for t in tasks:
        fresh = is_fresh(t, config, log)
        name = config["tasks"].get(t, {}).get("name", t)
        status = "FRESH (skip)" if fresh and t != task_id else "WILL RUN"
        print(f"    {name}: {status}")

    print()
    for t in tasks:
        if t == task_id or not is_fresh(t, config, log):
            run_task(t, config, log)


# ============================================
# STATUS
# ============================================
def show_status(config, log):
    print(f"\n{'='*70}")
    print(f"  SCHEDULER STATUS")
    print(f"  {datetime.now().strftime('%d %B %Y, %I:%M %p')}")
    print(f"{'='*70}")

    print(f"\n  {'Task':<30} {'Last Run':<20} {'Status':<8} {'Fresh?':<8} {'Age'}")
    print(f"  {'-'*70}")

    for task_id, task in config["tasks"].items():
        run_info = log["runs"].get(task_id, {})
        last = run_info.get("last_success", "Never")[:16] if run_info.get("last_success") else "Never"
        success = "OK" if run_info.get("success") else "FAIL" if run_info.get("last_run") else "—"
        fresh = "Yes" if is_fresh(task_id, config, log) else "No"
        enabled = "" if task.get("enabled", True) else " [DISABLED]"

        age = ""
        if run_info.get("last_success"):
            try:
                age_h = (datetime.now() - datetime.fromisoformat(run_info["last_success"])).total_seconds() / 3600
                age = f"{age_h:.1f}h"
            except:
                pass

        print(f"  {task['name']:<30} {last:<20} {success:<8} {fresh:<8} {age}{enabled}")

    # Pipelines
    print(f"\n  Pipelines:")
    for name, tasks in config["pipelines"].items():
        task_names = [config["tasks"].get(t, {}).get("name", t) for t in tasks]
        print(f"    {name}: {' → '.join(task_names)}")


# ============================================
# DAEMON MODE (continuous scheduling)
# ============================================
def run_daemon(config, log):
    """Run continuously — check schedules and execute"""
    print(f"\n{'='*60}")
    print(f"  SCHEDULER DAEMON MODE")
    print(f"  Daily pipeline: {config.get('daily_pipeline_time', '08:30')}")
    print(f"  Monitors: every 2-8 hours")
    print(f"  Press Ctrl+C to stop")
    print(f"{'='*60}")

    last_daily = None
    last_monitor = None
    check_interval = 60  # check every 60 seconds

    while True:
        now = datetime.now()
        current_time = now.strftime("%H:%M")
        pipeline_time = config.get("daily_pipeline_time", "08:30")

        # Daily pipeline
        today_str = now.strftime("%Y-%m-%d")
        if current_time >= pipeline_time and last_daily != today_str:
            print(f"\n  [DAEMON] Daily pipeline triggered at {current_time}")
            run_pipeline("daily", config, log)
            last_daily = today_str

        # Monitor pipeline (every 2 hours)
        if last_monitor is None or (now - last_monitor).total_seconds() > 7200:
            print(f"\n  [DAEMON] Monitor triggered at {current_time}")
            run_pipeline("monitor", config, log)
            last_monitor = now

        time.sleep(check_interval)


# ============================================
# MAIN
# ============================================
def main():
    parser = argparse.ArgumentParser(description='GoAmrita Central Scheduler v1.0')
    parser.add_argument('--run', nargs='+', help='Run: daily, monitor, weekly, task <id>, from <id>')
    parser.add_argument('--status', action='store_true', help='Show task status')
    parser.add_argument('--daemon', action='store_true', help='Run continuously')
    parser.add_argument('--force', action='store_true', help='Force run even if fresh')
    args = parser.parse_args()

    config = load_config()
    log = load_log()

    if args.status:
        show_status(config, log)
        return 0

    if args.daemon:
        try:
            run_daemon(config, log)
        except KeyboardInterrupt:
            print("\n  Daemon stopped.")
        return 0

    if args.run:
        cmd = args.run[0]

        if cmd in ('daily', 'monitor', 'weekly'):
            run_pipeline(cmd, config, log, force=args.force)

        elif cmd == 'task' and len(args.run) > 1:
            task_id = args.run[1]
            run_task(task_id, config, log, force=args.force)

        elif cmd == 'from' and len(args.run) > 1:
            task_id = args.run[1]
            run_from(task_id, config, log)

        else:
            # Try as task ID directly
            if cmd in config["tasks"]:
                run_task(cmd, config, log, force=args.force)
            else:
                print(f"Unknown: {cmd}")
                print("Usage: --run daily | monitor | weekly | task <id> | from <id>")
                return 1
    else:
        parser.print_help()
        print("\nTasks available:")
        for tid, t in config["tasks"].items():
            print(f"  {tid:<20} {t['name']}")

    return 0


if __name__ == "__main__":
    sys.exit(main())
