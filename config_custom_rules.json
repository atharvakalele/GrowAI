{
  "version": "1.0",
  "rules": [
    {
      "id": "rule_001",
      "name": "Pause High Loss Campaigns",
      "enabled": true,
      "applies_to": "campaign",
      "conditions": [
        {
          "field": "campaign.cost",
          "operator": ">",
          "value": 1000
        },
        {
          "field": "campaign.purchases7d",
          "operator": "=",
          "value": 0
        }
      ],
      "condition_logic": "AND",
      "actions": [
        {
          "type": "pause_campaign",
          "reason": "Zero sales with Rs.1000+ spend"
        }
      ],
      "schedule": "daily",
      "priority": 1,
      "created": "2026-04-13",
      "last_triggered": "2026-04-13T19:35:07.713500",
      "trigger_count": 1
    },
    {
      "id": "rule_002",
      "name": "Scale Star Campaigns",
      "enabled": true,
      "applies_to": "campaign",
      "conditions": [
        {
          "field": "campaign.clickThroughRate",
          "operator": ">",
          "value": 1.5
        },
        {
          "field": "campaign.purchases7d",
          "operator": ">",
          "value": 5
        },
        {
          "field": "product_profit.true_profit",
          "operator": ">",
          "value": 200
        }
      ],
      "condition_logic": "AND",
      "actions": [
        {
          "type": "increase_budget",
          "value": 20,
          "reason": "Star campaign with good CTR + orders + profit"
        }
      ],
      "schedule": "daily",
      "priority": 2,
      "created": "2026-04-13",
      "last_triggered": null,
      "trigger_count": 0
    },
    {
      "id": "rule_003",
      "name": "Alert Buy Box Lost",
      "enabled": true,
      "applies_to": "product",
      "conditions": [
        {
          "field": "buy_box.is_ours",
          "operator": "=",
          "value": false
        },
        {
          "field": "buy_box.buy_box_status",
          "operator": "=",
          "value": "LOST"
        }
      ],
      "condition_logic": "AND",
      "actions": [
        {
          "type": "send_alert",
          "message": "Buy Box lost on {asin}!"
        },
        {
          "type": "reduce_budget",
          "value": 50,
          "reason": "No Buy Box = ads less effective"
        }
      ],
      "schedule": "every_2hr",
      "priority": 1,
      "created": "2026-04-13",
      "last_triggered": null,
      "trigger_count": 0
    }
  ],
